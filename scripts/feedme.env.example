# FeedMe read-only verification — LOCAL ONLY. No secrets in git.
#
# Put these into .env.local (already gitignored) and fill in real values:
#
#   1. Open .env.local
#   2. Add the three FEEDME_* vars below with your real values
#   3. NEVER commit real token values
#
# The Bearer token (DevTools → Network → postgres-query → Headers →
# Authorization). Paste the JWT WITHOUT the leading "Bearer ".
FEEDME_BEARER_TOKEN=

# From the FeedMe portal URL (businessId / restaurantId).
FEEDME_BUSINESS_ID=
FEEDME_RESTAURANT_ID=

# Optional — path to the captured Daily Sales postgres-query body.
# Defaults to scripts/feedme-daily-sales.query.json
# FEEDME_QUERY_FILE=scripts/feedme-daily-sales.query.json

# Optional — set to 1 to print the full raw response (debug only).
# FEEDME_DEBUG_DUMP=1
